views:
  - type: cards
    name: 视图
    filters:
      and:
        - file.folder == "书籍目录"
    cardSize: 180
    image: note.cover
    imageFit: contain
    imageAspectRatio: 0.65
  - type: cards
    name: View
    filters:
      and:
        - file.folder == "书籍目录"
    order:
      - file.name
    image: note.cover
    imageFit: contain
